#!/bin/bash

set -e

if [[ -z $ROMARCHY_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env ROMARCHY_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/romarchy-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\033[0m"' ERR

gum style --border normal --border-foreground 6 --padding "1 2" \
  "Ready to update?" \
  "" \
  "• You cannot stop the update once you start!" \
  "• Make sure you're connected to power or have a full battery" \
  "" \
  "System packages will be updated"

echo

if ! gum confirm "Continue with update?"; then
  echo "Update cancelled"
  exit 0
fi

system-update-perform