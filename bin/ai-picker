#!/bin/bash

DESKTOP_DIR="$HOME/.local/share/applications"

start_walker_service() {
    if ! pgrep -f "walker --gapplication-service" > /dev/null 2>&1; then
        nohup walker --gapplication-service > /dev/null 2>&1 &
        sleep 0.3
    fi
}

start_walker_service

CHOICE=$(find "$DESKTOP_DIR" -maxdepth 1 -name "*.desktop" -exec basename {} .desktop \; 2>/dev/null | \
    grep -E "^(Grok|Gemini|ChatGPT|Claude)" | \
    sort | \
    walker --dmenu -p "AI" --width 295 --minheight 1 --maxheight 300 2>/dev/null)

if [[ -z "$CHOICE" ]]; then
    exit 0
fi

DESKTOP_FILE="$DESKTOP_DIR/${CHOICE}.desktop"
if [[ -f "$DESKTOP_FILE" ]]; then
    xdg-desktop-menu forceupdate 2>/dev/null || true
    exec gtk-launch "$CHOICE" 2>/dev/null || exec env GTK_USE_PORTAL=0 gtk-launch "$CHOICE"
fi