#!/bin/bash

# Adjust keyboard backlight using brightnessctl + swayosd-client for OSD.
# Matches omarchy implementation exactly.
# Usage: brightness-keyboard <up|down|cycle>

step="${1:-up}"

# Find keyboard backlight device
device=""
for candidate in /sys/class/leds/*kbd_backlight*; do
  [[ -e $candidate ]] && device="$(basename "$candidate")" && break
done

# Exit if no keyboard backlight device found (omarchy style)
[[ -z $device ]] && echo "No keyboard backlight device found" >&2 && exit 1

# Get max brightness
max_brightness="$(brightnessctl --device="$device" max)"

# Get current brightness
current_brightness="$(brightnessctl --device="$device" get)"

# Calculate new brightness based on step (omarchy uses 10% steps for keyboard)
if [[ "$step" == "up" ]]; then
  new_brightness=$((current_brightness + max_brightness * 10 / 100))
  (( new_brightness > max_brightness )) && new_brightness=$max_brightness
  brightnessctl --device="$device" set -- "$new_brightness" >/dev/null
elif [[ "$step" == "down" ]]; then
  new_brightness=$((current_brightness - max_brightness * 10 / 100))
  (( new_brightness < 0 )) && new_brightness=0
  brightnessctl --device="$device" set -- "$new_brightness" >/dev/null
elif [[ "$step" == "cycle" ]]; then
  # Cycle through 0%, 33%, 66%, 100%
  percent=$((current_brightness * 100 / max_brightness))
  if ((percent == 0)); then
    new_brightness=$((max_brightness * 33 / 100))
  elif ((percent <= 33)); then
    new_brightness=$((max_brightness * 66 / 100))
  elif ((percent <= 66)); then
    new_brightness=$max_brightness
  else
    new_brightness=0
  fi
  brightnessctl --device="$device" set -- "$new_brightness" >/dev/null
fi

new_brightness="$(brightnessctl --device="$device" get)"
percent=$((new_brightness * 100 / max_brightness))

# Show OSD using swayosd-client (omarchy style with monitor targeting)
progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

# Get focused monitor (omarchy pattern)
monitor=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true).name')

swayosd-client \
  --monitor "$monitor" \
  --custom-icon keyboard-brightness \
  --custom-progress "$progress" \
  --custom-progress-text "${percent}%"
