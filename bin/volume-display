#!/bin/bash

# Adjust volume using pamixer + swayosd-client for OSD.
# Usage: volume-display <+N%|-N%|toggle>

step="${1:-+5%}"

if [[ "$step" == "toggle" ]]; then
  pamixer -t >/dev/null
else
  step_clean="${step//%/}"
  if [[ "$step" == *"+"* ]]; then
    pamixer -i "${step_clean#+}" >/dev/null
  else
    pamixer -d "${step_clean#-}" >/dev/null
  fi
fi

new_percent=$(pamixer --get-volume)
is_muted=$(pamixer --get-mute)

if [[ "$is_muted" == "true" ]]; then
  icon="audio-volume-muted"
  percent=0
else
  if ((new_percent == 0)); then
    icon="audio-volume-low"
  elif ((new_percent < 50)); then
    icon="audio-volume-medium"
  else
    icon="audio-volume-high"
  fi
  percent=$new_percent
fi

monitor=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true).name')

progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

swayosd-client \
  --monitor "$monitor" \
  --custom-icon "$icon" \
  --custom-progress "$progress" \
  --custom-progress-text "${percent}%"
