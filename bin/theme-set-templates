#!/bin/bash

ROMARCHY_DIR="${ROMARCHY_DIR:-$HOME/.local/share/romarchy}"
TEMPLATES_DIR="$ROMARCHY_DIR/default/themed"
THEME_NAME="$1"

if [[ -z "$THEME_NAME" ]]; then
    echo "Usage: theme-set-templates <theme-name>"
    exit 1
fi

THEME_DIR="$ROMARCHY_DIR/themes/$THEME_NAME"
COLORS_FILE="$THEME_DIR/colors.toml"
OUTPUT_DIR="$HOME/.config/btop/themes"

hex_to_rgb() {
    local hex="${1#\#}"
    printf "%d,%d,%d" "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

if [[ ! -f "$COLORS_FILE" ]]; then
    echo "No colors.toml found for theme: $THEME_NAME"
    exit 1
fi

mkdir -p "$OUTPUT_DIR"

sed_script=$(mktemp)

while IFS='=' read -r key value; do
    key="${key//[\"\' ]/}"
    [[ $key && $key != \#* ]] || continue
    value="${value#*[\"\']}"
    value="${value%%[\"\']*}"
    
    printf 's|{{ %s }}|%s|g\n' "$key" "$value"
    printf 's|{{ %s_strip }}|%s|g\n' "$key" "${value#\#}"
    if [[ $value =~ ^# ]]; then
        rgb=$(hex_to_rgb "$value")
        echo "s|{{ ${key}_rgb }}|${rgb}|g"
    fi
done < "$COLORS_FILE" > "$sed_script"

for tpl in "$TEMPLATES_DIR"/*.tpl; do
    [[ -f "$tpl" ]] || continue
    filename=$(basename "$tpl" .tpl)
    
    if [[ "$filename" == "btop.theme" ]]; then
        output_file="$OUTPUT_DIR/${THEME_NAME}.theme"
        sed -f "$sed_script" -e "s/{{ theme_name }}/$THEME_NAME/g" "$tpl" > "$output_file"
        echo "Generated: $output_file"
    fi
done

rm "$sed_script"