#!/bin/bash

TEMPLATES_DIR="$ROMARCHY_PATH/default/themed"
USER_TEMPLATES_DIR="$HOME/.config/romarchy/themed"
NEXT_THEME_DIR="$HOME/.config/romarchy/current/next-theme"
COLORS_FILE="$NEXT_THEME_DIR/colors.toml"

hex_to_rgb() {
  local hex="${1#\#}"
  printf "%d,%d,%d" "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

if [[ -f $COLORS_FILE ]]; then
  sed_script=$(mktemp)

  while IFS='=' read -r key value; do
    key="${key//[\"\' ]/}"
    [[ $key && $key != \#* ]] || continue
    value="${value#*[\"\']}"
    value="${value%%[\"\']*}"

    printf 's|{{ %s }}|%s|g\n' "$key" "$value"
    printf 's|{{ %s_strip }}|%s|g\n' "$key" "${value#\#}"
    if [[ $value =~ ^# ]]; then
      rgb=$(hex_to_rgb "$value")
      echo "s|{{ ${key}_rgb }}|${rgb}|g"
    fi
  done <"$COLORS_FILE" >"$sed_script"

  shopt -s nullglob

  for tpl in "$USER_TEMPLATES_DIR"/*.tpl "$TEMPLATES_DIR"/*.tpl; do
    filename=$(basename "$tpl" .tpl)
    output_path="$NEXT_THEME_DIR/$filename"

    sed -f "$sed_script" "$tpl" >"$output_path"
  done

  rm "$sed_script"
fi