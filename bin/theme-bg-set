#!/bin/bash

if [[ -z $1 ]]; then
  echo "Usage: theme-bg-set <path-to-image>" >&2
  exit 1
fi

BACKGROUND="$1"
CURRENT_BACKGROUND_LINK="$HOME/.config/romarchy/current/background"

ln -nsf "$BACKGROUND" "$CURRENT_BACKGROUND_LINK"

pkill -x swaybg
setsid uwsm-app -- swaybg -i "$CURRENT_BACKGROUND_LINK" -m fill >/dev/null 2>&1 &