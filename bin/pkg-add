#!/bin/bash
# Add packages if missing (pacman + AUR via yay)
# No romarchy- prefix per naming convention

ROMARCHY_DIR="${ROMARCHY_DIR:-$HOME/.local/share/romarchy}"

for pkg in "$@"; do
  # Check if already installed
  if pacman -Q "$pkg" &>/dev/null; then
    echo -e "  \033[32m✓\033[0m $pkg (installed)"
    continue
  elif command -v yay &>/dev/null && yay -Q "$pkg" &>/dev/null; then
    echo -e "  \033[32m✓\033[0m $pkg (installed from AUR)"
    continue
  fi

  # Install
  echo -n "  Installing $pkg... "
  if pacman -Si "$pkg" &>/dev/null 2>&1; then
    sudo pacman -S --noconfirm --needed "$pkg" && echo -e "\033[32m✓\033[0m" || echo -e "\033[31m✗\033[0m"
  elif command -v yay &>/dev/null; then
    yay -S --noconfirm --needed "$pkg" && echo -e "\033[32m✓\033[0m" || echo -e "\033[31m✗\033[0m"
  else
    echo -e "\033[31m✗\033[0m yay not available for AUR package"
  fi
done

# Verify installation
for pkg in "$@"; do
  if ! pacman -Q "$pkg" &>/dev/null && ! (command -v yay &>/dev/null && yay -Q "$pkg" &>/dev/null); then
    echo "Error: Package '$pkg' did not install" >&2
    exit 1
  fi
done
