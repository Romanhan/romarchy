#!/bin/bash

ROMARCHY_DIR="${ROMARCHY_DIR:-$HOME/.local/share/romarchy}"
USER_THEMES_DIR="$HOME/.config/romarchy/themes"
OFFICIAL_THEMES_DIR="$ROMARCHY_DIR/themes"

echo "Available themes:"

if [[ -d "$USER_THEMES_DIR" ]]; then
    for theme_dir in "$USER_THEMES_DIR"/*; do
        if [[ -d "$theme_dir" ]]; then
            echo "  $(basename "$theme_dir") (user)"
        fi
    done
fi

for theme_dir in "$OFFICIAL_THEMES_DIR"/*; do
    if [[ -d "$theme_dir" ]]; then
        echo "  $(basename "$theme_dir")"
    fi
done
