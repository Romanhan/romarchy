#!/bin/bash

# Returns a formatted battery status string with percentage and power draw/charge.
# Used by the battery notification hotkey (SUPER + CTRL + ALT + B).

battery_info=$(upower -i "$(upower -e | grep BAT)")

percentage=$(echo "$battery_info" | awk '/percentage/ {
    print int($2)
    exit
}')

power_rate=$(echo "$battery_info" | awk '/energy-rate/ {
    rounded = sprintf("%.1f", $2)
    sub(/\.0$/, "", rounded)
    print rounded
    exit
}')

state=$(echo "$battery_info" | awk '/state/ { print $2; exit }')
time_remaining=$(battery-remaining-time)
capacity=$(battery-capacity)

if [[ $state == "charging" ]]; then
  echo "箚겧    Battery ${percentage}%  쨌  ${time_remaining} to full  쨌  ${power_rate}W / ${capacity}Wh"
else
  echo "箚겧    Battery ${percentage}%  쨌  ${time_remaining} left  쨌  ${power_rate}W / ${capacity}Wh"
fi
