#!/bin/bash

set -e

echo -e "\e[32mUpdate Romarchy\e[0m"

system-update-time

hyprctl keyword debug:suppress_errors true &>/dev/null || true

git -C $ROMARCHY_PATH pull --autostash
git -C $ROMARCHY_PATH --no-pager diff --check || git -C $ROMARCHY_PATH reset --merge

hyprctl reload &>/dev/null || true
