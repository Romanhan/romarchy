#!/bin/bash

CURRENT_THEME_DIR=~/.config/romarchy/current/theme
COLORS_FILE="$CURRENT_THEME_DIR/colors.toml"
GTK3_DIR=~/.config/gtk-3.0
GTK4_DIR=~/.config/gtk-4.0
OUTPUT_FILE="$CURRENT_THEME_DIR/gtk.css"

extract_color() {
    grep -m1 "^$1" "$COLORS_FILE" | cut -d'=' -f2 | tr -d ' "' | tr -d '#'
}

if [[ ! -f "$COLORS_FILE" ]]; then
    exit 0
fi

mkdir -p "$GTK3_DIR"
mkdir -p "$GTK4_DIR"
mkdir -p "$HOME/.config/xdg-desktop-portal"

p_bg="#$(extract_color background)"
p_fg="#$(extract_color foreground)"
c0="#$(extract_color color0)"
c1="#$(extract_color color1)"
c2="#$(extract_color color2)"
c3="#$(extract_color color3)"
c4="#$(extract_color color4)"
c5="#$(extract_color color5)"
c6="#$(extract_color color6)"
c7="#$(extract_color color7)"
c8="#$(extract_color color8)"
c9="#$(extract_color color9)"
c10="#$(extract_color color10)"
c11="#$(extract_color color11)"
c12="#$(extract_color color12)"
c13="#$(extract_color color13)"
c14="#$(extract_color color14)"
c15="#$(extract_color color15)"

# Determine light/dark mode
if [[ -f "$CURRENT_THEME_DIR/light.mode" ]]; then
    is_light=true
    gtk_theme_suffix=""
else
    is_light=false
    gtk_theme_suffix="-dark"
fi

# Determine icon theme
if [[ -f "$CURRENT_THEME_DIR/icons.theme" ]]; then
    icon_theme_name=$(cat "$CURRENT_THEME_DIR/icons.theme")
else
    icon_theme_name="Yaru-blue"
fi

{
    echo "@define-color background     ${p_bg};"
    echo "@define-color foreground     ${p_fg};"
    echo "@define-color black          ${p_bg};"
    echo "@define-color red            ${c1};"
    echo "@define-color green          ${c2};"
    echo "@define-color yellow         ${c3};"
    echo "@define-color blue           ${c4};"
    echo "@define-color magenta        ${c5};"
    echo "@define-color cyan           ${c6};"
    echo "@define-color white          ${c7};"
    echo "@define-color bright_black   ${c8};"
    echo "@define-color bright_red     ${c9};"
    echo "@define-color bright_green   ${c10};"
    echo "@define-color bright_yellow  ${c11};"
    echo "@define-color bright_blue    ${c12};"
    echo "@define-color bright_magenta ${c13};"
    echo "@define-color bright_cyan    ${c14};"
    echo "@define-color bright_white   ${c15};"
    echo ""
    echo "@define-color accent_bg_color @blue;"
    echo "@define-color accent_fg_color @background;"
    echo "@define-color accent_color @cyan;"
    echo ""
    echo "@define-color window_bg_color @background;"
    echo "@define-color window_fg_color @foreground;"
    echo ""
    echo "@define-color view_bg_color @black;"
    echo "@define-color view_fg_color @foreground;"
    echo "@define-color sidebar_bg_color @black;"
    echo "@define-color sidebar_fg_color @foreground;"
    echo "@define-color sidebar_backdrop_color @black;"
    echo "@define-color sidebar_shade_color @black;"
    echo ""
    echo "@define-color headerbar_bg_color @background;"
    echo "@define-color headerbar_fg_color @foreground;"
    echo "@define-color headerbar_backdrop_color @black;"
    echo "@define-color headerbar_shade_color @black;"
    echo "@define-color card_bg_color @background;"
    echo "@define-color card_fg_color @foreground;"
    echo ""
    echo "@define-color popover_bg_color @black;"
    echo "@define-color popover_fg_color @foreground;"
    echo ""
    echo "@define-color destructive_bg_color @red;"
    echo "@define-color destructive_fg_color @background;"
    echo "@define-color success_bg_color @green;"
    echo "@define-color success_fg_color @background;"
    echo "@define-color warning_bg_color @yellow;"
    echo "@define-color warning_fg_color @background;"
    echo "@define-color error_bg_color @red;"
    echo "@define-color error_fg_color @background;"
    echo ""
    echo "@define-color dialog_bg_color @background;"
    echo "@define-color dialog_fg_color @foreground;"
    echo "@define-color borders alpha(@foreground, 0.1);"
    echo ""
    echo "@define-color theme_fg_color @foreground;"
    echo "@define-color theme_text_color @foreground;"
    echo "@define-color theme_bg_color @background;"
    echo "@define-color theme_base_color @black;"
    echo "@define-color theme_selected_bg_color @blue;"
    echo "@define-color theme_selected_fg_color @background;"
    echo "@define-color insensitive_bg_color @background;"
    echo "@define-color insensitive_fg_color @bright_black;"
    echo "@define-color insensitive_base_color @black;"
    echo "@define-color theme_unfocused_fg_color @foreground;"
    echo "@define-color theme_unfocused_text_color @foreground;"
    echo "@define-color theme_unfocused_bg_color @background;"
    echo "@define-color theme_unfocused_base_color @black;"
    echo "@define-color theme_unfocused_selected_bg_color @blue;"
    echo "@define-color theme_unfocused_selected_fg_color @background;"
    echo "@define-color unfocused_insensitive_color @bright_black;"
    echo "@define-color unfocused_borders alpha(@foreground, 0.1);"
    echo "@define-color warning_color @yellow;"
    echo "@define-color error_color @red;"
    echo "@define-color success_color @green;"
    echo "@define-color destructive_color @red;"
    echo ""
    echo "@define-color content_view_bg @black;"
    echo "@define-color text_view_bg @black;"
    echo ""
    echo "messagedialog {"
    echo "    background-color: @dialog_bg_color;"
    echo "}"
    echo ""
    echo "messagedialog label {"
    echo "    color: @dialog_fg_color;"
    echo "    font-size: 14pt;"
    echo "    font-weight: bold;"
    echo "}"
    echo ""
    echo "messagedialog .secondary-text {"
    echo "    font-size: 10pt;"
    echo "    font-style: italic;"
    echo "}"
    echo ""
    echo "messagedialog button {"
    echo "    background-color: @black;"
    echo "    color: @foreground;"
    echo "    border: 1px solid @bright_black;"
    echo "    padding: 10px;"
    echo "}"
    echo ""
    echo "messagedialog button:hover {"
    echo "    background-color: @blue;"
    echo "}"
    echo ""
    echo "banner revealer widget {"
    echo "    background: @bright_black;"
    echo "    padding: 5px;"
    echo "    color: @foreground;"
    echo "}"
    echo ""
    echo "alertdialog.background {"
    echo "    background-color: @dialog_bg_color;"
    echo "    color: @dialog_fg_color;"
    echo "}"
    echo ""
    echo "alertdialog .titlebar {"
    echo "    background-color: @headerbar_bg_color;"
    echo "    color: @headerbar_fg_color;"
    echo "}"
    echo ""
    echo "alertdialog box {"
    echo "    background-color: @dialog_bg_color;"
    echo "}"
    echo ""
    echo "alertdialog label {"
    echo "    color: @dialog_fg_color;"
    echo "}"
    echo ""
    echo "filechooser .dialog-action-box {"
    echo "    border-top: 1px solid @bright_black;"
    echo "}"
    echo ""
    echo "filechooser .dialog-action-box:backdrop {"
    echo "    border-top-color: @black;"
    echo "}"
    echo ""
    echo "filechooser #pathbarbox {"
    echo "    border-bottom: 1px solid @bright_black;"
    echo "}"
    echo ""
    echo "filechooserbutton:drop(active) {"
    echo "    box-shadow: none;"
    echo "    border-color: transparent;"
    echo "}"
    echo ""
    echo "toast {"
    echo "    background-color: @black;"
    echo "    color: @foreground;"
    echo "}"
    echo ""
    echo "toast button.circular.flat.image-button:hover {"
    echo "    color: @background;"
    echo "    background-color: @red;"
    echo "}"
} > "$OUTPUT_FILE"

cp -f "$OUTPUT_FILE" "$GTK3_DIR/gtk.css"
cp -f "$OUTPUT_FILE" "$GTK4_DIR/gtk.css"

prefer_dark=$([ "$is_light" = "false" ] && echo "1" || echo "0")

cat > "$GTK3_DIR/settings.ini" << EOF
[Settings]
gtk-application-prefer-dark-theme=$prefer_dark
gtk-theme-name=adw-gtk3${gtk_theme_suffix}
gtk-icon-theme-name=$icon_theme_name
gtk-font-name=Sans 12
EOF

cat > "$GTK4_DIR/settings.ini" << EOF
[Settings]
gtk-application-prefer-dark-theme=$prefer_dark
gtk-theme-name=adw-gtk3${gtk_theme_suffix}
gtk-icon-theme-name=$icon_theme_name
gtk-font-name=Sans 12
EOF

cat > "$HOME/.config/xdg-desktop-portal/portal.conf" << EOF
[preferred]
default=gtk
EOF

if [[ "$is_light" = "true" ]]; then
    gsettings set org.gnome.desktop.interface color-scheme "prefer-light"
    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3-tmp
    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3
else
    gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"
    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3-tmp-dark
    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3-dark
fi

gsettings set org.gnome.desktop.interface icon-theme "$icon_theme_name"
gsettings set org.gnome.desktop.interface cursor-theme "Adwaita"
gsettings set org.gnome.desktop.interface cursor-size 24

pkill -f xdg-desktop-portal-gtk 2>/dev/null || true
sleep 0.5
pkill -x nautilus 2>/dev/null || true
nautilus --quit &>/dev/null || true
sleep 1
nautilus &>/dev/null &

exit 0