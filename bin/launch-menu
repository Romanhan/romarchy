#!/bin/bash

ROMARCHY_DIR="${ROMARCHY_DIR:-$HOME/.local/share/romarchy}"
export PATH="$ROMARCHY_DIR/bin:$PATH"

BACK_TO_EXIT=false

toggle_existing_menu() {
    if pgrep -f "walker.*--dmenu" >/dev/null; then
        walker --close >/dev/null 2>&1
        exit 0
    fi
}

back_to() {
    local parent_menu="$1"

    if [[ $BACK_TO_EXIT == "true" ]]; then
        exit 0
    elif [[ -n $parent_menu ]]; then
        "$parent_menu"
    else
        show_main_menu
    fi
}

USER_EXTENSIONS="$HOME/.config/romarchy/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

start_walker_service() {
    if ! pgrep -f "walker --gapplication-service" > /dev/null 2>&1; then
        nohup walker --gapplication-service > /dev/null 2>&1 &
        sleep 0.3
    fi
}

menu() {
    local prompt="$1"
    local options="$2"
    local width="${3:-295}"

    echo -e "$options" | walker --dmenu -p "$prompt" --width "$width" --minheight 1 --maxheight 300 2>/dev/null
}

main_menu() {
    echo -e "¾░Ć╗  Apps
¾▒Éŗ  System
Ņ»Å  Style
’ĆĪ  Update
¾░¢¤  Web Apps
¾░Éź  Power"
}

power_menu() {
    echo -e "¾░Éź  Shutdown
¾░£ē  Reboot
ŌÅŠ  Suspend
¾░īŠ  Lock"
}

system_menu() {
    echo -e "’ć½  Wifi
¾░é»  Bluetooth
¾░Ź╣  Monitors
’ä£  Keyboard"
}

style_menu() {
    echo -e "¾░Ėī  Themes
   ¾░ÅÜ  Backgrounds
   ŅÖÖ  Fonts"
}

update_menu() {
    echo -e "¾░ÜĢ  Update System
    ¾░Żć  Update Romarchy"
}

webapps_menu() {
    echo -e "¾░Ć│  Install Web App
¾░¬Ä  Remove Web App"
}

show_font_menu() {
    local font_list=$("$ROMARCHY_DIR/bin/font-list")
    local current=$("$ROMARCHY_DIR/bin/font-current")
    
    local choice=$(menu "Font" "$font_list" "350")
    
    if [[ -z "$choice" || "$choice" == "CNCLD" ]]; then
        return 1
    fi
    
    "$ROMARCHY_DIR/bin/font-set" "$choice"
}

run_action() {
    local choice="$1"

    case "$choice" in
        *"Shutdown")
            "$ROMARCHY_DIR/bin/system-shutdown"
            ;;
        *"Reboot")
            "$ROMARCHY_DIR/bin/system-reboot"
            ;;
        *"Suspend")
            "$ROMARCHY_DIR/bin/system-suspend"
            ;;
        *"Lock")
            "$ROMARCHY_DIR/bin/lock-screen"
            ;;
        *"Wifi")
            "$ROMARCHY_DIR/bin/launch-wifi"
            ;;
        *"Bluetooth")
            "$ROMARCHY_DIR/bin/launch-bluetooth"
            ;;
        *"Monitors")
            hyprctl dispatch exec "kitty -e nvim ~/.local/share/romarchy/config/hypr/monitors.conf"
            ;;
        *"Keyboard")
            hyprctl dispatch exec "kitty -e nvim ~/.local/share/romarchy/config/hypr/input.conf"
            ;;
        *"Themes")
            launch-walker -m menus:romarchythemes --width 800 --minheight 400
            ;;
        *"Backgrounds")
            launch-walker -m menus:romarchyBackgroundSelector --width 800 --minheight 400
            ;;
        *"Fonts")
            show_font_menu
            ;;
        *"Update System")
            launch-floating-terminal system-update-perform
            ;;
        *"Update Romarchy")
            launch-floating-terminal system-update-git
            ;;
        *"Install Web App")
            uwsm-app -- kitty -e "$ROMARCHY_DIR/bin/webapp-install"
            ;;
        *"Remove Web App")
            uwsm-app -- kitty -e "$ROMARCHY_DIR/bin/webapp-remove"
            ;;
    esac
}

show_apps_menu() {
    launch-walker
}

show_system_menu() {
    local choice=$(menu "System" "$(system_menu)")
    if [[ -z "$choice" ]]; then
        back_to show_main_menu
    else
        run_action "$choice"
    fi
}

show_style_menu() {
    local choice=$(menu "Style" "$(style_menu)")
    if [[ -z "$choice" ]]; then
        back_to show_main_menu
    else
        run_action "$choice"
    fi
}

show_power_menu() {
    local choice=$(menu "Power" "$(power_menu)")
    if [[ -z "$choice" ]]; then
        back_to show_main_menu
    else
        run_action "$choice"
    fi
}

show_webapps_menu() {
    local choice=$(menu "Web Apps" "$(webapps_menu)")
    if [[ -z "$choice" ]]; then
        back_to show_main_menu
    else
        run_action "$choice"
    fi
}

show_update_menu() {
    local choice=$(menu "Update" "$(update_menu)")
    if [[ -z "$choice" ]]; then
        back_to show_main_menu
    else
        run_action "$choice"
    fi
}

show_main_menu() {
    start_walker_service
    local choice
    choice=$(echo -e "$(main_menu)" | walker --dmenu -p "Go" --width 295 --minheight 1 --maxheight 630 2>/dev/null)
    [[ -z "$choice" ]] && exit 0

    case "$choice" in
        *Web\ Apps*) show_webapps_menu ;;
        *Apps) show_apps_menu ;;
        *System) show_system_menu ;;
        *Style) show_style_menu ;;
        *Power*) show_power_menu ;;
        *Update*) show_update_menu ;;
        *) run_action "$choice" ;;
    esac
}

go_to_menu() {
    case "${1,,}" in
    *apps*) show_apps_menu ;;
    *system*) show_system_menu ;;
    *style*) show_style_menu ;;
    *power*) show_power_menu ;;
    *webapps*) show_webapps_menu ;;
    *update*) show_update_menu ;;
    *) show_main_menu ;;
    esac
}

toggle_existing_menu

if [[ -n $1 ]]; then
    BACK_TO_EXIT=true
    go_to_menu "$1"
else
    show_main_menu
fi