#!/bin/bash

ROMARCHY_DIR="${ROMARCHY_DIR:-$HOME/.local/share/romarchy}"

start_walker_service() {
    if ! pgrep -f "walker --gapplication-service" > /dev/null 2>&1; then
        nohup walker --gapplication-service > /dev/null 2>&1 &
        sleep 0.3
    fi
}

menu() {
    local prompt="$1"
    local options="$2"
    local width="${3:-295}"
    
    echo -e "$options" | walker --dmenu -p "$prompt" --width "$width" --minheight 1 --maxheight 300 2>/dev/null
}

main_menu() {
    echo -e "ůįÄĽ  Apps
ůĪźč  System
ÓĮŹ  Style
ůį£á  Update
ůįź•  Power Menu
ůįįė  Web Apps"
}

power_menu() {
    echo -e "ůįź•  Shutdown
ůįúČ  Reboot
‚Źĺ  Suspend
ůįĆĺ  Lock"
}

apps_menu() {
    echo -e "ÔíČ  Terminal
ÔĄĒ  File Manager
ůįäĮ  Browser
ÓüÖ  Editor
ůį®ě  VS Code"
}

system_menu() {
    echo -e "Ôáę  Wifi
ůįāĮ  Bluetooth
ůįćĻ  Monitors
ÔĄú  Keyboard"
}

style_menu() {
    echo -e "ůįłĆ  Themes
  ůįŹö  Backgrounds
  Óôô  Fonts"
}

webapps_menu() {
    echo -e "ůįįė  Install Web App
ůįĶģ  Remove Web App"
}

show_font_menu() {
    local font_list=$("$ROMARCHY_DIR/bin/font-list")
    local current=$("$ROMARCHY_DIR/bin/font-current")
    
    local choice=$(menu "Font" "$font_list" "350")
    
    if [[ -z "$choice" || "$choice" == "CNCLD" ]]; then
        return 1
    fi
    
    "$ROMARCHY_DIR/bin/font-set" "$choice"
}

show_menu() {
    local menu_type="$1"
    local prompt="$2"
    
    case "$menu_type" in
        main) main_menu ;;
        power) power_menu ;;
        apps) apps_menu ;;
        system) system_menu ;;
        style) style_menu ;;
        webapps) webapps_menu ;;
    esac | walker --dmenu -p "$prompt" --width 295 --minheight 1 --maxheight 300 2>/dev/null
}

run_action() {
    local choice="$1"
    
    case "$choice" in
        *"Shutdown")
            "$ROMARCHY_DIR/bin/system-shutdown"
            ;;
        *"Reboot")
            "$ROMARCHY_DIR/bin/system-reboot"
            ;;
        *"Suspend")
            "$ROMARCHY_DIR/bin/system-suspend"
            ;;
        *"Lock")
            "$ROMARCHY_DIR/bin/lock-screen"
            ;;
        *"Terminal")
            "$ROMARCHY_DIR/bin/launch-terminal"
            ;;
        *"File Manager")
            "$ROMARCHY_DIR/bin/launch-yazi"
            ;;
        *"Browser")
            "$ROMARCHY_DIR/bin/launch-browser"
            ;;
        *"Editor")
            "$ROMARCHY_DIR/bin/launch-editor"
            ;;
        *"VS Code")
            uwsm app -- code
            ;;
        *"Wifi")
            "$ROMARCHY_DIR/bin/launch-wifi"
            ;;
        *"Bluetooth")
            "$ROMARCHY_DIR/bin/launch-bluetooth"
            ;;
        *"Monitors")
            hyprctl dispatch exec "kitty -e nvim ~/.local/share/romarchy/config/hypr/monitors.conf"
            ;;
        *"Keyboard")
            hyprctl dispatch exec "kitty -e nvim ~/.local/share/romarchy/config/hypr/input.conf"
            ;;
        *"Themes")
            "$ROMARCHY_DIR/bin/theme-current"
            ;;
        *"Backgrounds")
            "$ROMARCHY_DIR/bin/bg-install"
            ;;
        *"Fonts")
            show_font_menu
            ;;
        *"Update")
            kitty --title "Romarchy Update" -e sh -c "cd $ROMARCHY_DIR && git pull && echo 'Done. Press Enter to exit.' && read"
            ;;
*"Install Web App")
uwsm-app -- kitty -e "$ROMARCHY_DIR/bin/webapp-install"
            ;;
        *"Remove Web App")
            uwsm-app -- kitty -e "$ROMARCHY_DIR/bin/webapp-remove"
            ;;
    esac
}

navigate() {
    local current="main"
    
    start_walker_service
    
    while true; do
        local choice=$(show_menu "$current" "Menu")
        
        if [[ -z "$choice" ]]; then
            if [[ "$current" != "main" ]]; then
                current="main"
                continue
            else
                exit 0
            fi
        fi
        
        case "$choice" in
            *Web\ Apps)
                current="webapps"
                ;;
            *Apps)
                current="apps"
                ;;
            *System)
                current="system"
                ;;
            *Style)
                current="style"
                ;;
            *Power\ Menu)
                current="power"
                ;;
            *Back)
                current="main"
                ;;
            *)
                run_action "$choice"
                exit 0
                ;;
        esac
    done
}

navigate