#!/bin/bash

restart_walker() {
  # Kill existing walker
  pkill -9 -x walker 2>/dev/null
  sleep 1

  # Restart via uwsm-app (matches how other apps are started)
  uwsm-app -- walker --gapplication-service >/dev/null 2>&1 &
  sleep 1
  pgrep -x walker >/dev/null && echo "Walker restarted successfully"
}

if (( EUID == 0 )); then
  SCRIPT_OWNER=$(stat -c '%U' "$0")
  USER_UID=$(id -u "$SCRIPT_OWNER")
  systemd-run --uid="$SCRIPT_OWNER" --setenv=XDG_RUNTIME_DIR="/run/user/$USER_UID" \
    bash -c "$(declare -f restart_walker); restart_walker"
else
  restart_walker
fi