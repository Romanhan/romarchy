#!/bin/bash

# Run inside a PTY so pacman/yay keep showing progress bars
if [[ -z $ROMARCHY_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env ROMARCHY_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/romarchy-update.log"
fi

clear
echo "Starting system update..."
echo ""

# Ensure screensaver/sleep doesn't set in during updates
hyprctl dispatch tagwindow +noidle &>/dev/null || true

# Update system packages (pacman + AUR)
yay -Syu --noconfirm

# Remove orphan packages
yay -Rns $(yay -Qtdq 2>/dev/null) --noconfirm 2>/dev/null || true

# Re-enable screensaver/sleep after updates
hyprctl dispatch tagwindow -- -noidle &>/dev/null || true

echo ""
echo "Update complete!"

# Check if reboot is needed (kernel update)
if [[ ! -d /usr/lib/modules/$(uname -r) ]]; then
  echo ""
  echo "Kernel updated - reboot required"
  echo ""
  read -p "Reboot now? (y/N) " -n 1
  echo
  [[ $REPLY =~ ^[Yy]$ ]] && system-reboot
fi

echo ""
echo "Press Enter to close..."
read
