#!/bin/bash

# Take a screenshot of a region or fullscreen.
# Saves to ~/Pictures/Screenshots by default, can be changed via ROMARCHY_SCREENSHOT_DIR.

[[ -f ~/.config/user-dirs.dirs ]] && source ~/.config/user-dirs.dirs
OUTPUT_DIR="${ROMARCHY_SCREENSHOT_DIR:-${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots}"

if [[ ! -d $OUTPUT_DIR ]]; then
  mkdir -p "$OUTPUT_DIR"
  notify-send "Created screenshot directory: $OUTPUT_DIR" -u normal -t 2000
fi

pkill slurp && exit 0

MODE="${1:-region}"

case "$MODE" in
fullscreen)
  SELECTION=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | "\(.x),\(.y) \(.width / .scale | floor)x\(.height / .scale | floor)"')
  ;;
region | *)
  SELECTION=$(slurp 2>/dev/null)
  ;;
esac

[[ -z $SELECTION ]] && exit 0

FILENAME="screenshot-$(date +'%Y-%m-%d_%H-%M-%S').png"
FILEPATH="$OUTPUT_DIR/$FILENAME"

grim -g "$SELECTION" "$FILEPATH" || exit 1
wl-copy <"$FILEPATH"

(
  echo "$FILEPATH" > /tmp/romarchy-last-screenshot
  notify-send "Screenshot saved" "$FILEPATH" -t 10000 -i "$FILEPATH" -A "edit=Edit"
) &
