#!/bin/bash

echo

if [[ ! -d /usr/lib/modules/$(uname -r) ]]; then
  gum confirm "Linux kernel has been updated. Reboot?" && systemctl reboot
elif [[ -f "$HOME/.local/state/romarchy/restart-required" ]]; then
  gum confirm "Updates require reboot. Ready?" && systemctl reboot
fi

running_hyprland=$(readlink /proc/$(pgrep -x Hyprland)/exe 2>/dev/null)
if [[ $running_hyprland == *"(deleted)"* ]]; then
  gum confirm "Hyprland has been updated. Restart?" && systemctl reboot
fi