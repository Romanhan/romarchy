#!/bin/bash

# Adjust display brightness using brightnessctl + swayosd-client for OSD.
# Matches omarchy implementation exactly.
# Usage: brightness-display <raise|lower|+N|-N>

step="${1:-raise}"

# Find backlight device (same order as omarchy)
device=""
for candidate in amdgpu_bl* intel_backlight acpi_video*; do
  [[ -e /sys/class/backlight/$candidate ]] && device="$candidate" && break
done

# Fallback: use first available backlight device
[[ -z $device ]] && device="$(ls -1 /sys/class/backlight 2>/dev/null | head -n1)"

# Exit if no device found
[[ -z $device ]] && echo "No backlight device found" >&2 && exit 1

# Get max brightness
max_brightness="$(brightnessctl --device="$device" max)"

# Get current brightness (use -- to separate)
current_brightness="$(brightnessctl --device="$device" get)"

# Calculate new brightness based on step
if [[ "$step" == "raise" ]]; then
  new_brightness=$((current_brightness + max_brightness * 10 / 100))
  (( new_brightness > max_brightness )) && new_brightness=$max_brightness
  brightnessctl --device="$device" set -- "$new_brightness" >/dev/null
elif [[ "$step" == "lower" ]]; then
  new_brightness=$((current_brightness - max_brightness * 10 / 100))
  (( new_brightness < 0 )) && new_brightness=0
  brightnessctl --device="$device" set -- "$new_brightness" >/dev/null
else
  # Direct value (e.g., +5%, -5%, 50%)
  brightnessctl --device="$device" set -- "$step" >/dev/null
  new_brightness="$(brightnessctl --device="$device" get)"
fi

percent=$((new_brightness * 100 / max_brightness))

# Show OSD using swayosd-client (omarchy style with monitor targeting)
progress="$(awk -v p="$percent" 'BEGIN{printf "%.2f", p/100}')"
[[ $progress == "0.00" ]] && progress="0.01"

# Get focused monitor (omarchy pattern)
monitor=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true).name')

swayosd-client \
  --monitor "$monitor" \
  --custom-icon display-brightness \
  --custom-progress "$progress" \
  --custom-progress-text "${percent}%"
