#!/bin/bash
set -eEo pipefail

# Define locations (Omarchy-style)
export ROMARCHY_DIR="${ROMARCHY_DIR:-$HOME/.local/share/romarchy}"
export ROMARCHY_INSTALL="$ROMARCHY_DIR/install"
export ROMARCHY_INSTALL_LOG_FILE="/var/log/romarchy-install.log"
export PATH="$ROMARCHY_DIR/bin:$PATH"

# Help
if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
  echo "Usage: romarchy-install"
  echo ""
  echo "Installs Romarchy (requires Arch Linux with BTRFS + LUKS + Limine)"
  echo ""
  echo "See: https://github.com/Romanhan/romarchy"
  exit 0
fi

# Initialize log
sudo mkdir -p /var/log
sudo touch "$ROMARCHY_INSTALL_LOG_FILE"
sudo chmod 666 "$ROMARCHY_INSTALL_LOG_FILE" 2>/dev/null || true

echo "" >> "$ROMARCHY_INSTALL_LOG_FILE"
echo "━━━ Romarchy Installation Started: $(date) ━━━" >> "$ROMARCHY_INSTALL_LOG_FILE"
echo "" >> "$ROMARCHY_INSTALL_LOG_FILE"

# Run installation stages (Omarchy-style)
source "$ROMARCHY_INSTALL/helpers/all.sh"
source "$ROMARCHY_INSTALL/preflight/all.sh"
source "$ROMARCHY_INSTALL/packs/all.sh"
source "$ROMARCHY_INSTALL/config/all.sh"
source "$ROMARCHY_INSTALL/login/all.sh"
source "$ROMARCHY_INSTALL/post-install/all.sh"

echo "" >> "$ROMARCHY_INSTALL_LOG_FILE"
echo "━━━ Romarchy Installation Completed: $(date) ━━━" >> "$ROMARCHY_INSTALL_LOG_FILE"

echo ""
success "Romarchy installation complete!"
echo ""
info "Log: /var/log/romarchy-install.log"
info "Reboot to apply all changes"
