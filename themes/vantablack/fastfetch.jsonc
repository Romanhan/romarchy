{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "small",
    "padding": {
      "top": 1,
      "bottom": 0,
      "left": 1,
      "right": 1
    },
    "color": {
      "1": "#8d8d8d"
    }
  },
  "display": {
    "separator": "  ",
    "color": {
      "keys": "#8d8d8d",
      "title": "#8d8d8d"
    },
    "key": {
      "width": 16,
      "type": "string"
    }
  },
  "modules": [
    {
      "type": "custom",
      "format": "{#keys}╭────────────╮"
    },
    {
      "type": "os",
      "key": "│  OS       │"
    },
    {
      "type": "kernel",
      "key": "│  Kernel   │"
    },
    {
      "type": "host",
      "key": "│  Host     │"
    },
    {
      "type": "cpu",
      "key": "│  CPU      │"
    },
    {
      "type": "gpu",
      "key": "│  GPU      │"
    },
    {
      "type": "display",
      "key": "│ 󱄄 Display  │"
    },
    {
      "type": "wm",
      "key": "│  WM       │"
    },
    {
      "type": "shell",
      "key": "│  Shell    │"
    },
    {
      "type": "terminal",
      "key": "│  Terminal │"
    },
    {
      "type": "packages",
      "key": "│ 󰏖 Packages │"
    },
    {
      "type": "memory",
      "key": "│  Memory   │"
    },
    {
      "type": "disk",
      "key": "│ 󰋊 Disk     │"
    },
    {
      "type": "command",
      "key": "│ 󱦟 OS Age   │",
      "text": "echo $(( ($(date +%s) - $(stat -c %W /)) / 86400 )) days"
    },
    {
      "type": "colors",
      "key": "│ 󰸌 Colors   │",
      "symbol": "circle"
    },
    {
      "type": "custom",
      "format": "{#keys}╰────────────╯"
    }
  ],
  "colors": {
    "enabled": true,
    "bold": true,
    "valuesWithColor": true,
    "palette": [
      "#0d0d0d",
      "#a4a4a4",
      "#b6b6b6",
      "#cecece",
      "#8d8d8d",
      "#9b9b9b",
      "#b0b0b0",
      "#ececec"
    ]
  }
}
